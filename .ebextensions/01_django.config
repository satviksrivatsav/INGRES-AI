container_commands:
  01_migrate:
    command: "source /var/app/venv/*/bin/activate && python3 manage.py migrate"
    leader_only: true
  02_collectstatic:
    command: "source /var/app/venv/*/bin/activate && python3 manage.py collectstatic --noinput"
  03_chown_db:
    command: "sudo chown webapp:webapp db.sqlite3"
    ignoreErrors: true
  04_chown_dir:
    command: "sudo chown webapp:webapp ."
    ignoreErrors: true
